#include <iostream>
#include <clocale>   
#include "Weapon.h"

using namespace std;

int main()
{
    setlocale(LC_ALL, "Russian");
    Weapon sword("Меч", 25, 2);
    sword.printInfo();
    Weapon staff;
    staff.printInfo();

    //  Создаём динамический объект 
    Weapon* pWeapon = new Weapon("Лук", 15, 1.2f);
    pWeapon->printInfo();

    // Проверяем работу методов 
    float maxWeight = 5.0f;
    cout << "\nМожет ли поднять " << sword.name << " при макс. весе " << maxWeight << "? ";
    if (sword.canLift(maxWeight))
    {
        cout << "Да (макс. вес меньше веса оружия)" << endl;
    }
    else
    {
        cout << "Нет (макс. вес больше или равен весу оружия)" << endl;
    }

    // Суммарный вес меча и посоха
    float sumWeight = sword.totalWeight(staff);
    cout << "Суммарный вес меча и посоха: " << sumWeight << endl;

    // Вес меча + 10.0
    float sumWithExtra = sword.totalWeight(10.0f);
    cout << "Вес меча + 10.0: " << sumWithExtra << endl;

    // --- Удаляем динамический объект (вызовется деструктор) 
    delete pWeapon;

    return 0;
}
