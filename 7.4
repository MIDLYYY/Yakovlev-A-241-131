#include <iostream>
#include <vector>
#include <map>
#include <string>

using namespace std;

// Функция для вывода вектора
void printVector(const vector<float>& v)
{
    for (float x : v)
    {
        cout << x << " ";
    }
    cout << endl;
}

// Класс Settings (нестатическая версия)
class Settings
{
private:
    map<string, string> settings;   // поле для хранения пар ключ-значение

public:
    // Добавление пары
    void Add(const string& key, const string& value)
    {
        settings[key] = value;
    }

    // Получение значения по ключу
    string Get(const string& key)
    {
        return settings[key];
    }

    // Вывод всех настроек
    void Print()
    {
        cout << "Содержимое Settings:" << endl;
        for (const auto& pair : settings)
        {
            cout << pair.first << " : " << pair.second << endl;
        }
    }
};

// Статическая версия класса Settings
class StaticSettings
{
private:
    static map<string, string> settings;   // статическое поле

public:
    static void Add(const string& key, const string& value)
    {
        settings[key] = value;
    }

    static string Get(const string& key)
    {
        return settings[key];
    }

    static void Print()
    {
        cout << "Содержимое StaticSettings:" << endl;
        for (const auto& pair : settings)
        {
            cout << pair.first << " : " << pair.second << endl;
        }
    }
};

// Инициализация статического поля класса StaticSettings
map<string, string> StaticSettings::settings;

int main()
{
    setlocale(LC_ALL, "Russian");

    // --- Работа с вектором ---
    cout << "=== Работа с вектором ===" << endl;

    // 1. Пустой вектор float
    vector<float> v;

    // 2. Добавляем 5 элементов
    v.push_back(1.1f);
    v.push_back(2.2f);
    v.push_back(3.3f);
    v.push_back(4.4f);
    v.push_back(5.5f);

    // 3-4. Выводим вектор через функцию
    cout << "Вектор после добавления 5 элементов: ";
    printVector(v);

    // 5. Вставляем элемент между 3 и 4 (индексы 2 и 3)
    // Вставляем после 3-го элемента, т.е. на позицию с индексом 3
    v.insert(v.begin() + 3, 9.9f);

    // 6. Проверяем
    cout << "Вектор после вставки 9.9 между 3 и 4: ";
    printVector(v);

    // 7. Удаляем последний элемент
    v.pop_back();

    // 8. Проверяем
    cout << "Вектор после удаления последнего элемента: ";
    printVector(v);

    // --- Работа с классом Settings (нестатическая версия) ---
    cout << "\n=== Нестатический Settings ===" << endl;

    Settings mySettings;
    mySettings.Add("username", "ivan");
    mySettings.Add("theme", "dark");
    mySettings.Add("language", "ru");

    cout << "Get(theme): " << mySettings.Get("theme") << endl;
    mySettings.Print();

    // --- Работа с классом StaticSettings (статическая версия) ---
    cout << "\n=== Статический StaticSettings ===" << endl;

    // Вызываем статические методы без создания объекта
    StaticSettings::Add("volume", "80");
    StaticSettings::Add("difficulty", "hard");
    StaticSettings::Add("resolution", "1920x1080");

    cout << "Get(difficulty): " << StaticSettings::Get("difficulty") << endl;
    StaticSettings::Print();

    return 0;
}
