#include <iostream>
#include <string>

using namespace std;

int main()
{
    setlocale(LC_ALL, "Russian");

    // Просим пользователя ввести строку
    cout << "Введите строку: ";
    string input;
    getline(cin, input);  // считываем всю строку, включая пробелы

    // Выводим подстроку со 2-го по 4-й символ (включительно)
    // Пользователь считает символы с 1, поэтому 2-й символ = индекс 1, 4-й символ = индекс 3
    if (input.length() >= 4)
    {
        string sub = input.substr(1, 3);  // начиная с индекса 1, 3 символа
        cout << "Подстрока со 2-го по 4-й символ: " << sub << endl;
    }
    else
    {
        cout << "Строка слишком коротка для выделения подстроки." << endl;
    }

    // 3. Ищем первое вхождение символа 'a'
    size_t pos = input.find('a');
    if (pos != string::npos)
    {
        cout << "Индекс первого вхождения 'a': " << pos << " (нумерация с 0)" << endl;
    }
    else
    {
        cout << "Символа a не найдено" << endl;
    }

    return 0;
}
