#include <iostream>
#include <string>

using namespace std;

// Собственный класс исключения для года рождения
class YearException
{
public:
    // Перечисление возможных ошибок
    enum ErrorCode
    {
        TOO_OLD,    // год меньше 1850
        TOO_YOUNG,  // год больше текущего
        NEGATIVE    // отрицательное число
    };

    ErrorCode code;  // код ошибки

    // Конструктор
    YearException(ErrorCode c) : code(c) {}
};

int main()
{
    setlocale(LC_ALL, "Russian");

    // --- Часть 1: ввод числа 1, 2 или 3 ---
    cout << "Введите число 1, 2 или 3: ";
    int num;
    cin >> num;

    try
    {
        if (num == 1)
        {
            cout << "Один" << endl;
        }
        else if (num == 2)
        {
            cout << "Два" << endl;
        }
        else if (num == 3)
        {
            cout << "Три" << endl;
        }
        else
        {
            throw 1;  // выбрасываем любое исключение
        }
    }
    catch (...)
    {
        cout << "Некорректное значение" << endl;
    }

    //  ввод года рождения с использованием собственного исключения 
    // Для упрощения используем константу текущего года (без <ctime>)
    const int CURRENT_YEAR = 2025;

    cout << "\nВведите год своего рождения: ";
    int year;
    cin >> year;

    try
    {
        if (year < 1850)
        {
            throw YearException(YearException::TOO_OLD);
        }
        if (year > CURRENT_YEAR)
        {
            throw YearException(YearException::TOO_YOUNG);
        }
        if (year < 0)
        {
            throw YearException(YearException::NEGATIVE);
        }

        // Если всё хорошо
        cout << "Спасибо!" << endl;
    }
    catch (const YearException& e)
    {
        switch (e.code)
        {
        case YearException::TOO_OLD:
            cout << "Что-то не верится..." << endl;
            break;
        case YearException::TOO_YOUNG:
            cout << "Вы ещё не родились" << endl;
            break;
        case YearException::NEGATIVE:
            cout << "Вы ввели отрицательное число!" << endl;
            break;
        }
    }

    return 0;
}
