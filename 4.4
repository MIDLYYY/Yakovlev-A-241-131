#include <iostream>
#include <clocale>
#include "Weapon.h"
#include "Characteristic.h"
#include "MyMath.h"

using namespace std;

int main()
{
    setlocale(LC_ALL, "Russian");

    //  Работа с Weapon (теперь с геттерами/сеттерами) 
    cout << "\n=== Тестирование класса Weapon  ===" << endl;
    Weapon sword("Меч", 25, 2);
    sword.printInfo();

    // Используем get-методы
    cout << "\nНазвание (через геттер): " << sword.getName() << endl;
    cout << "Урон (через геттер): " << sword.getDamage() << endl;
    cout << "Вес (через геттер): " << sword.getWeight() << endl;

    // Используем set-метод для урона
    sword.setDamage(30);
    cout << "Урон после изменения: " << sword.getDamage() << endl;

    // Попытка установить отрицательный урон
    sword.setDamage(-5);  // должно вывести предупреждение

    // Класс Characteristic и дружественность
    cout << "\n=== Тестирование класса Characteristic ===" << endl;
    Characteristic hero(15);  // сила героя = 15
    float totalDamage = hero.GetDamage(sword);
    cout << "Сила героя: 15, урон меча: " << sword.getDamage()
         << ", суммарный урон: " << totalDamage << endl;

    //  Класс MyMath со статическими методами и счётчиком
    cout << "\n=== Тестирование класса MyMath ===" << endl;
    int a = 10, b = 3;
    cout << "Add: " << MyMath::Add(a, b) << endl;
    cout << "Sub: " << MyMath::Sub(a, b) << endl;
    cout << "Mult: " << MyMath::Mult(a, b) << endl;
    cout << "Div: " << MyMath::Div(a, b) << endl;

    // Проверяем количество вызовов
    cout << "Количество вызовов методов MyMath: " << MyMath::GetCallCount() << endl;

    // Ещё несколько вызовов
    MyMath::Add(5, 5);
    MyMath::Sub(10, 1);
    cout << "После ещё двух вызовов: " << MyMath::GetCallCount() << endl;

    return 0;
}
