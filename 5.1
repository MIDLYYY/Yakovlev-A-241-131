#include <iostream>
#include <clocale>
#include "Weapon.h"
#include "Characteristic.h"
#include "Player.h"
#include "MagicWeapon.h"

using namespace std;

int main()
{
    setlocale(LC_ALL, "Russian");

    // Тестирование класса Weapon 
    cout << "\n=== Тестирование Weapon с типом ===" << endl;
    Weapon sword("Меч", 25, 2, WeaponType::ONEHANDED);
    Weapon bow("Длинный лук", 15, 1.5f, WeaponType::BOW);
    Weapon staff; // по умолчанию Посох, тип ONEHANDED

    sword.printInfo();
    bow.printInfo();
    staff.printInfo();

    // Вывод текстового представления типа через if 
    cout << "\nТип меча: ";
    if (sword.getType() == WeaponType::ONEHANDED)
        cout << "Одноручное оружие" << endl;
    else if (sword.getType() == WeaponType::TWOHANDED)
        cout << "Двуручное оружие" << endl;
    else if (sword.getType() == WeaponType::BOW)
        cout << "Лук" << endl;
    else if (sword.getType() == WeaponType::CROSSBOW)
        cout << "Арбалет" << endl;

    cout << "Тип лука: ";
    if (bow.getType() == WeaponType::ONEHANDED)
        cout << "Одноручное оружие" << endl;
    else if (bow.getType() == WeaponType::TWOHANDED)
        cout << "Двуручное оружие" << endl;
    else if (bow.getType() == WeaponType::BOW)
        cout << "Лук" << endl;
    else if (bow.getType() == WeaponType::CROSSBOW)
        cout << "Арбалет" << endl;

    //  Тестирование структуры Player
    cout << "\n=== Тестирование структуры Player ===" << endl;
    Player player;
    player.id = 1;
    player.login = "Hero123";
    player.password = "qwerty";
    player.printInfo();

    //  Тестирование класса MagicWeapon 
    cout << "\n=== Тестирование MagicWeapon ===" << endl;
    MagicWeapon fireStaff("Огненный посох", 5.0f, 3.0f, WeaponType::TWOHANDED, 12.0f);
    MagicWeapon defaultMagic;

    fireStaff.printInfo();
    cout << "Дополнительный урон: " << fireStaff.getExtraDamage() << endl;
    cout << "Общий урон: " << fireStaff.getDamage() + fireStaff.getExtraDamage() << endl;

    defaultMagic.printInfo();
    cout << "Дополнительный урон: " << defaultMagic.getExtraDamage() << endl;
    cout << "Общий урон: " << defaultMagic.getDamage() + defaultMagic.getExtraDamage() << endl;

    // Проверка унаследованных геттеров
    cout << "\nИмя (геттер): " << fireStaff.getName() << endl;
    cout << "Вес (геттер): " << fireStaff.getWeight() << endl;
    
    // Вывод типа без отдельной функции
    cout << "Тип: ";
    if (fireStaff.getType() == WeaponType::ONEHANDED)
        cout << "Одноручное оружие" << endl;
    else if (fireStaff.getType() == WeaponType::TWOHANDED)
        cout << "Двуручное оружие" << endl;
    else if (fireStaff.getType() == WeaponType::BOW)
        cout << "Лук" << endl;
    else if (fireStaff.getType() == WeaponType::CROSSBOW)
        cout << "Арбалет" << endl;

    //  Проверка Characteristic с новым оружием 
    cout << "\n=== Проверка Characteristic ===" << endl;
    Characteristic hero(15);
    cout << "Урон героя с оружием: " << hero.GetDamage(fireStaff) << " (сила + урон оружия)" << endl;

    return 0;
}
