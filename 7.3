#include <iostream>
#include <fstream>
#include <string>
#include <cmath>
#include <iomanip>
#include <limits>

using namespace std;

int main()
{
    setlocale(LC_ALL, "Russian");

    // радиус окружности 
    cout << "Введите радиус окружности: ";
    double r;
    cin >> r;

    double length = 2 * M_PI * r;  // M_PI определена в cmath
    cout << "Длина окружности: " << length << endl;

    // Округляем до 3 знаков после запятой
    cout << fixed << setprecision(3);
    cout << "Длина окружности (с округлением): " << length << endl;

    // Очищаем буфер ввода перед getline
    cin.ignore(numeric_limits<streamsize>::max(), '\n');

    // работа с файлом 
    string filename = "data.txt";
    string command;

    while (true)
    {
        cout << "\nВведите строку (или read/erase/exit): ";
        getline(cin, command);

        if (command == "exit")
        {
            break;
        }
        else if (command == "read")
        {
            // Чтение и вывод содержимого файла
            ifstream inFile(filename);
            if (inFile.is_open())
            {
                string line;
                cout << "Содержимое файла:\n";
                while (getline(inFile, line))
                {
                    cout << line << endl;
                }
                inFile.close();
            }
            else
            {
                cout << "Файл ещё не создан или не может быть открыт." << endl;
            }
        }
        else if (command == "erase")
        {
            // Очистка файла (открываем в режиме trunc)
            ofstream outFile(filename, ios::trunc);
            outFile.close();
            cout << "Файл очищен." << endl;
        }
        else
        {
            // Дозапись строки в файл
            ofstream outFile(filename, ios::app);
            if (outFile.is_open())
            {
                outFile << command << endl;
                outFile.close();
                cout << "Строка записана в файл." << endl;
            }
            else
            {
                cout << "Ошибка открытия файла для записи." << endl;
            }
        }
    }

    return 0;
}
