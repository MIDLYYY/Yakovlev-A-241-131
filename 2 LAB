#include <iostream>
#include <string>
#include <clocale> 
using namespace std;

class Vehicle {
private:
    string brand;
    int maxSpeed;
    int currentSpeed;

public:
    Vehicle(string b, int max) {
        brand = b;
        maxSpeed = max;
        currentSpeed = 0;
    }

    void accelerate(int increment) {
        if (currentSpeed + increment > maxSpeed)
            currentSpeed = maxSpeed;
        else
            currentSpeed += increment;
    }

    void brake(int decrement) {
        if (currentSpeed - decrement < 0)
            currentSpeed = 0;
        else
            currentSpeed -= decrement;
    }

    void getStatus() {
        cout << brand << ": макс. " << maxSpeed
            << ", сейчас " << currentSpeed << endl;
    }
};

int main() {
    setlocale(LC_ALL, "ru"); 

    // Создаем массив из 5 машин
    Vehicle park[5] = {
        Vehicle("Chery", 200),
        Vehicle("Lada", 150),
        Vehicle("BMW", 250),
        Vehicle("Bus", 100),
        Vehicle("Honda", 190)
    };

    // Ускоряем все
    park[0].accelerate(50);
    park[1].accelerate(30);
    park[2].accelerate(80);
    park[3].accelerate(20);
    park[4].accelerate(10);

    // Тормозим некоторые
    park[1].brake(50);
    park[3].brake(30);

    // Выводим статус
    for (int i = 0; i < 5; i++) {
        park[i].getStatus();
    }

    return 0;
}
