#include <iostream>
using namespace std;

// Функция, принимающая указатели на начало и конец массива и возвращающая сумму
int sumArray(int* begin,int* end) {
    int sum = 0;
    while (begin != end) {
        sum += *begin;
        ++begin;
    }
    return sum;
}

// Две простые функции: сложение и вычитание
int add(int a, int b) {
    return a + b;
}

int subtract(int a, int b) {
    return a - b;
}

// Функция, выбирающая операцию по символу и возвращающая указатель на неё
int (*getOperation(char op))(int, int) {
    if (op == '+')
        return add;
    else                
        return subtract;
}

int main() {
    // Проверка суммы массива
    int arr[] = { 1, 2, 3, 4, 5 };
    int* begin = arr;
    int* end = arr + 5;
    int total = sumArray(begin, end);
    cout << "Sum of array: " << total << endl;

    // Выбор операции и вызов по указателю
    char op = '+';
    int (*operation)(int, int) = getOperation(op);
    int res = operation(10, 5);
    cout << "10 " << op << " 5 = " << res << endl;

    op = '-';
    operation = getOperation(op);
    res = operation(10, 5);
    cout << "10 " << op << " 5 = " << res << endl;

    // Динамический указатель на float
    float* pFloat = new float(3.14159f);
    cout << "dynamic float: " << *pFloat << endl;
    //delete pFloat;

    return 0;
}
